generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model InsuranceCompany {
  id                  String          @id @default(cuid())
  name                String
  code                String          @unique
  logo                String?         @db.Text
  card_pattern        String?         // Regex like WAB-*
  service_type_mappings Json?         // e.g. {"MEDICINE": "GENERAL"} — maps one service type to another for ceiling sharing
  is_active           Boolean         @default(true)
  deleted_at          DateTime?
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  beneficiaries       Beneficiary[]
  service_policies    ServicePolicy[]
  transactions        Transaction[]
  wallet_consumptions WalletConsumption[]
  service_mappings    ServiceTypeMapping[]
  claims              Claim[]

  @@index([code])
}

model ServicePolicy {
  id                    String            @id @default(cuid())
  company_id            String
  service_type          String            // DENTAL, OPTICS, GENERAL, etc.
  annual_ceiling        Decimal?          @db.Decimal(12, 2)
  copay_percentage      Decimal           @db.Decimal(5, 2) @default(0)
  allow_partial_coverage Boolean          @default(true)
  is_active             Boolean           @default(true)
  effective_from        DateTime?
  effective_to          DateTime?
  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt
  company               InsuranceCompany  @relation(fields: [company_id], references: [id])

  @@unique([company_id, service_type])
  @@index([company_id, is_active])
}

model Facility {
  id                   String        @id @default(cuid())
  name                 String
  username             String        @unique
  password_hash        String
  created_at           DateTime      @default(now())
  is_admin             Boolean       @default(false)
  deleted_at           DateTime?
  must_change_password Boolean       @default(false)
  is_manager           Boolean       @default(false)
  manager_permissions  Json?
  is_employee          Boolean       @default(false)
  transactions         Transaction[]

  @@index([deleted_at])
  @@index([is_manager], map: "idx_facility_is_manager_fixed")
}

model Beneficiary {
  id                String            @id @default(cuid())
  card_number       String
  name              String
  
  // Legacy fields (kept for backward compatibility)
  total_balance     Decimal           @default(600) @db.Decimal(12, 2)
  remaining_balance Decimal           @default(600) @db.Decimal(12, 2)
  
  // New TPA fields
  company_id        String?
  company           InsuranceCompany? @relation(fields: [company_id], references: [id])
  
  status            BeneficiaryStatus @default(ACTIVE)
  created_at        DateTime          @default(now())
  birth_date        DateTime?
  phone_number      String?           
  city              String?           
  batch_number      String?           
  deleted_at        DateTime?
  failed_attempts   Int               @default(0)
  locked_until      DateTime?
  pin_hash          String?
  completed_via     String?
  is_legacy_card    Boolean           @default(false)
  notifications     Notification[]
  transactions      Transaction[]
  wallet_consumptions WalletConsumption[]
  claims            Claim[]

  @@index([card_number])
  @@index([deleted_at])
  @@index([status])
  @@index([company_id])
  @@index([name])
}

model Transaction {
  id                      String          @id @default(cuid())
  beneficiary_id          String
  facility_id             String
  company_id              String?         // Added for TPA
  
  amount                  Decimal         @db.Decimal(12, 2) // Gross Service Amount
  type                    TransactionType
  service_category        String?         // DENTAL, OPTICS, etc.
  
  // Financial Shares
  original_company_share  Decimal?        @db.Decimal(12, 2)
  original_patient_share  Decimal?        @db.Decimal(12, 2)
  actual_company_share    Decimal?        @db.Decimal(12, 2)
  actual_patient_share    Decimal?        @db.Decimal(12, 2)
  
  // Ceiling Audit
  remaining_ceiling_before Decimal?       @db.Decimal(12, 2)
  ceiling_consumed         Decimal?       @db.Decimal(12, 2)
  remaining_ceiling_after  Decimal?       @db.Decimal(12, 2)
  
  // Policy Snapshot & Metadata
  policy_snapshot         Json?           // Stores the policy rules at time of service
  calc_metadata           Json?           // Stores engine version, internal calculations
  
  created_at              DateTime        @default(now())
  is_cancelled            Boolean         @default(false)
  original_transaction_id String?
  idempotency_key         String?         @unique
  
  beneficiary             Beneficiary     @relation(fields: [beneficiary_id], references: [id])
  facility                Facility        @relation(fields: [facility_id], references: [id])
  company                 InsuranceCompany? @relation(fields: [company_id], references: [id])
  original_transaction    Transaction?    @relation("TransactionCorrection", fields: [original_transaction_id], references: [id])
  corrections             Transaction[]   @relation("TransactionCorrection")
  claim                   Claim?

  @@index([beneficiary_id])
  @@index([facility_id])
  @@index([company_id])
  @@index([created_at])
  @@index([beneficiary_id, is_cancelled, type])
  @@index([is_cancelled, type])
  @@index([service_category, created_at])
}

model AuditLog {
  id          String   @id @default(cuid())
  user        String
  action      String
  metadata    Json?
  created_at  DateTime @default(now())
  facility_id String?
  ip_address  String?

  @@index([facility_id, created_at])
  @@index([action, created_at])
  @@index([user])
}

model ImportJob {
  id                  String          @id @default(cuid())
  created_by          String
  status              ImportJobStatus @default(PENDING)
  payload             Json
  total_rows          Int             @default(0)
  processed_rows      Int             @default(0)
  inserted_rows       Int             @default(0)
  duplicate_rows      Int             @default(0)
  failed_rows         Int             @default(0)
  error_message       String?
  started_at          DateTime?
  completed_at        DateTime?
  created_at          DateTime        @default(now())
  skipped_rows_report Json?
  options             Json?
  rollback_data       Json?

  @@index([created_by, created_at])
  @@index([status])
}

model OtpCode {
  id           String   @id @default(cuid())
  phone_number String
  code         String
  expires_at   DateTime
  created_at   DateTime @default(now())
  is_used      Boolean  @default(false)

  @@index([phone_number, code])
  @@index([expires_at])
}

model CardIssuanceRegistry {
  id                String    @id @default(cuid())
  card_number       String
  card_number_upper String    @unique
  canonical_card    String
  beneficiary_name  String?
  birth_date        DateTime?
  phone_number      String?
  batch_number      String?
  city              String
  source_file       String?
  source_sheet      String?
  source_row        Int?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @default(now()) @updatedAt

  @@index([canonical_card])
  @@index([city])
  @@index([batch_number])
}

model CardIssuanceRegistryAll {
  id                String    @id // Format: cardUpper-batchNumber
  card_number       String
  card_number_upper String
  canonical_card    String
  beneficiary_name  String?
  birth_date        DateTime?
  phone_number      String?
  batch_number      String
  city              String
  source_file       String?
  source_sheet      String?
  source_row        Int?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @default(now()) @updatedAt

  @@index([card_number_upper])
  @@index([canonical_card])
  @@index([city])
  @@index([batch_number])
}

// ─── Wallet-Based Ceiling System ─────────────────────────────────────────
// WalletConsumption: رصيد السقف المتراكم لكل مستفيد-شركة-محفظة-سنة
model WalletConsumption {
  id              String          @id @default(cuid())
  beneficiary_id  String
  company_id      String
  wallet_type     String          // "GENERAL", "DENTAL", إلخ — الـ mapped type
  fiscal_year     Int
  consumed_amount Decimal         @default(0) @db.Decimal(12, 2)
  version         Int             @default(1)  // Optimistic locking
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  beneficiary Beneficiary        @relation(fields: [beneficiary_id], references: [id])
  company     InsuranceCompany    @relation(fields: [company_id], references: [id])

  @@unique([beneficiary_id, company_id, wallet_type, fiscal_year])
  @@index([beneficiary_id, company_id])
  @@index([company_id, wallet_type])
}

// ServiceTypeMapping: جدول رسم الخدمات للمحافظ — بديل JSON field
model ServiceTypeMapping {
  id           String @id @default(cuid())
  company_id   String
  service_type String // "MEDICINE", "SUPPLIES", إلخ
  mapped_to    String // "GENERAL", إلخ — المحفظة الحقيقية

  company InsuranceCompany @relation(fields: [company_id], references: [id])

  @@unique([company_id, service_type])
  @@index([company_id])
}

// Claim: طلب خصم معتمد (approved / partial / rejected)
model Claim {
  id                String          @id @default(cuid())
  beneficiary_id    String
  company_id        String?
  service_type      String
  wallet_type       String          // الـ mapped type (المحفظة الفعلية)
  requested_amount  Decimal         @db.Decimal(12, 2)
  approved_amount   Decimal         @db.Decimal(12, 2)
  status            ClaimStatus     @default(APPROVED)
  transaction_id    String?         @unique // link to Transaction
  idempotency_key   String?         @unique
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt

  beneficiary Beneficiary        @relation(fields: [beneficiary_id], references: [id])
  company     InsuranceCompany?   @relation(fields: [company_id], references: [id])
  transaction Transaction?        @relation(fields: [transaction_id], references: [id])

  @@index([beneficiary_id])
  @@index([company_id])
  @@index([created_at])
  @@index([status])
}

// ClaimAuditLog: سجل تدقيق لكل Claim (standalone, no relation to avoid circular deps)
model ClaimAuditLog {
  id              String   @id @default(cuid())
  claim_id        String
  action          String   // "WALLET_RESOLVED" | "LIMIT_CHECKED" | "APPROVED" | "PARTIAL" | "REJECTED" | "DEDUCTED"
  wallet_type     String?
  limit_annual    Decimal? @db.Decimal(12, 2)
  consumed_before Decimal? @db.Decimal(12, 2)
  consumed_after  Decimal? @db.Decimal(12, 2)
  requested       Decimal? @db.Decimal(12, 2)
  approved        Decimal? @db.Decimal(12, 2)
  remaining       Decimal? @db.Decimal(12, 2)
  notes           String?
  created_at      DateTime @default(now())

  @@index([claim_id])
  @@index([created_at])
}

enum ClaimStatus {
  APPROVED
  PARTIAL
  REJECTED
}

model Notification {
  id             String      @id @default(cuid())
  beneficiary_id String
  title          String
  message        String
  amount         Decimal?    @db.Decimal(12, 2)
  is_read        Boolean     @default(false)
  created_at     DateTime    @default(now())
  beneficiary    Beneficiary @relation(fields: [beneficiary_id], references: [id], onDelete: Cascade)

  @@index([beneficiary_id, is_read])
  @@index([beneficiary_id, created_at])
}

enum BeneficiaryStatus {
  ACTIVE
  FINISHED
  SUSPENDED
}

enum TransactionType {
  MEDICINE
  SUPPLIES
  CANCELLATION
  IMPORT
  SETTLEMENT
  DENTAL     // Added
  OPTICS     // Added
  GENERAL    // Added
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  ROLLED_BACK
}

model SystemSetting {
  key         String   @id
  value       String   @db.Text
  description String?
  updated_at  DateTime @default(now()) @updatedAt
}

model FamilyImportArchive {
  family_base_card       String    @id
  family_count_from_file Int?
  total_balance_from_file Decimal?  @db.Decimal(12, 2)
  used_balance_from_file  Decimal?  @db.Decimal(12, 2)
  source_row_number      Int?
  source_file_name       String?
  imported_by            String
  last_imported_at       DateTime
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
}

// Keeping legacy models for now to avoid migration issues
model RestoreJob {
  id                    String           @id @default(cuid())
  created_by            String
  status                RestoreJobStatus @default(PENDING)
  encrypted_payload     Bytes
  total_steps           Int              @default(0)
  completed_steps       Int              @default(0)
  current_phase         String?
  added_facilities      Int              @default(0)
  updated_facilities    Int              @default(0)
  added_beneficiaries   Int              @default(0)
  updated_beneficiaries Int              @default(0)
  added_transactions    Int              @default(0)
  skipped_transactions  Int              @default(0)
  added_audit_logs      Int              @default(0)
  added_notifications   Int              @default(0)
  skipped_notifications Int              @default(0)
  error_message         String?
  started_at            DateTime?
  completed_at          DateTime?
  created_at            DateTime         @default(now())
  updated_at            DateTime         @updatedAt
  added_admins          Int              @default(0)
  updated_admins        Int              @default(0)
  removed_beneficiaries Int              @default(0)

  @@index([created_by, created_at])
  @@index([status])
}

enum RestoreJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model CardNumberingArchive {
  id                String    @id @default(cuid())
  name              String
  employee_number   String
  relationship      String?   
  birth_date        DateTime? 
  phone_number      String?   
  original_date     String?   
  city              String?   
  original_city     String?   
  batch_number      String?   
  card_number       String    @unique
  status            CardNumberingStatus @default(READY)
  error_message     String?
  field3            String?
  match_percentage  Float?    
  mismatch_reasons  String?   
  created_at        DateTime  @default(now())
  migrated_at       DateTime?
  deleted_at        DateTime?
  source_file       String?

  @@index([card_number])
  @@index([employee_number])
  @@index([created_at])
  @@index([deleted_at])
}

enum CardNumberingStatus {
  READY
  MIGRATED
  DUPLICATE
  DUPLICATE_FILE
  DUPLICATE_SYSTEM
  ERROR
}
