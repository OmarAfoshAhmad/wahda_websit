# Production environment (used by docker-compose.prod.yml)
DATABASE_URL="postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/DB_NAME?schema=public"
JWT_SECRET="replace-with-long-random-secret"
BACKUP_ENCRYPTION_KEY="replace-with-backup-encryption-key"
BENEFICIARY_TOKEN_SECRET="replace-with-beneficiary-token-secret"
INITIAL_BALANCE="600"
PORT="3000"
APP_HOST_PORT="3101"
NODE_ENV="production"

# معرّف مرفق وعد (الأدمن الرئيسي) — مطلوب لاستيراد المعاملات من Excel
# احصل عليه بعد التشغيل الأول من: SELECT id FROM "Facility" WHERE is_admin=true LIMIT 1;
WAAD_FACILITY_ID=""

# ── Redis ──────────────────────────────────────────────────────────
# REDIS_URL يُبنى تلقائياً في docker-compose.prod.yml من REDIS_PASSWORD
REDIS_PASSWORD="replace-with-redis-password"

# Optional bootstrap admin on first run (only if no active admin exists)
DEFAULT_ADMIN_USERNAME="admin"
DEFAULT_ADMIN_PASSWORD="replace-with-admin-password"
DEFAULT_ADMIN_NAME="System Admin"

# Optional default password for imported/reset facility users
DEFAULT_FACILITY_PASSWORD="123456"
